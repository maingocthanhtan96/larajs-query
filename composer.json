{
    "name": "larajs/query-parser",
    "version": "1.0.0",
    "autoload": {
        "psr-4": {
            "LaraJS\\QueryParser\\": "src/"
        },
        "files": [
            "src/Helpers/Helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "tanmnt",
            "email": "maingocthanhtan96@gmail.com"
        }
    ],
    "suggest": {
        "staudenmeir/belongs-to-through": "^2.5"
    },
    "require": {
        "php": "^8.1",
        "staudenmeir/belongs-to-through": "^2.5",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/pagination": "^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.3",
        "laravel/pint": "^1.11",
        "mockery/mockery": "^1.6"
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraJS\\QueryParser\\Providers\\LaraJSQueryParserServiceProvider"
            ]
        }
    }
}
